  --message-file MESSAGE_FILE, -f MESSAGE_FILE
                        Specify a file containing the message to send the LLM, process
                        reply, then exit (disables chat mode) [env var: AIDER_MESSAGE_FILE]

  --read FILE           specify a read-only file (can be used multiple times) [env var:
                        AIDER_READ]
  --file FILE           specify a file to edit (can be used multiple times) [env var:
                        AIDER_FILE]

  --yes-always          Always say yes to every confirmation [env var: AIDER_YES_ALWAYS]


  --exit                Do all startup activities then exit before accepting user input
                        (debug) [env var: AIDER_EXIT]
